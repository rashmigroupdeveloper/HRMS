{
  "name": "hrms-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "worker": "tsx watch src/jobs/worker.ts",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "knip": "knip",
    "depcruise": "depcruise src --config .dependency-cruiser.cjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify": "npm run typecheck && npm run lint && npm run knip && npm run depcruise && npm run test && npm run build",
    "format": "prettier --write .",
    "seed:rbac": "tsx src/core/rbac/seed.ts",
    "migrate": "tsx -r dotenv/config node_modules/node-pg-migrate/bin/node-pg-migrate -j ts --ignore-pattern \".*\\.md\" up",
    "migrate:down": "tsx -r dotenv/config node_modules/node-pg-migrate/bin/node-pg-migrate -j ts --ignore-pattern \".*\\.md\" down",
    "migrate:create": "tsx -r dotenv/config node_modules/node-pg-migrate/bin/node-pg-migrate -j ts --ignore-pattern \".*\\.md\" create"
  },
  "dependencies": {
    "@orpc/openapi": "^1.14.7",
    "@orpc/server": "^1.14.7",
    "@orpc/zod": "^1.14.7",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "jose": "^6.2.3",
    "kysely": "^0.28.2",
    "pg": "^8.16.0",
    "pg-boss": "^12.25.1",
    "pino": "^9.7.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.0",
    "@types/node": "^22.15.0",
    "@types/pg": "^8.15.0",
    "@types/supertest": "^6.0.3",
    "dependency-cruiser": "^16.10.0",
    "eslint": "^9.30.0",
    "knip": "^5.61.0",
    "node-pg-migrate": "^7.9.0",
    "prettier": "^3.6.0",
    "supertest": "^7.1.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.0",
    "vitest": "^3.2.0"
  }
}
