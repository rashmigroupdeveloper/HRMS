# Copy to .env for local development. NEVER commit real values (docs/02 §2).

NODE_ENV=development
PORT=5100

# --- Database ---
# Local development uses the machine's PostgreSQL directly.
# One-time setup in psql as a superuser:
#   CREATE USER hrms WITH PASSWORD 'change_me';
#   CREATE DATABASE hrms OWNER hrms;
DATABASE_URL=postgres://hrms:change_me@localhost:5432/hrms
