# Copy to .env for local development. NEVER commit real values (docs/02 §2).
#
#   cp .env.example .env
#
# Or run from repo root:
#   bash scripts/setup-local-env.sh

# --- Runtime (required now) ---
NODE_ENV=development
PORT=5100
LOG_LEVEL=info

# --- Database (required now) ---
# One-time Postgres setup (as a superuser):
#   CREATE USER hrms WITH PASSWORD 'hrms_local_dev';
#   CREATE DATABASE hrms OWNER hrms;
#   GRANT ALL PRIVILEGES ON DATABASE hrms TO hrms;
DATABASE_URL=postgres://hrms:hrms_local_dev@localhost:5432/hrms

# --- Auth (Stage 0.4 — uncomment when auth module lands) ---
# JWT_ACCESS_SECRET=generate-with-openssl-rand-hex-32
# JWT_REFRESH_SECRET=generate-with-openssl-rand-hex-32
# JWT_ACCESS_TTL_MINUTES=15
# JWT_REFRESH_TTL_DAYS=7
# BCRYPT_ROUNDS=12

# --- SSO / ATS integration (Phase 1+) ---
# ATS_JWT_PUBLIC_KEY=
# CORS_ORIGIN=http://localhost:5173

# --- Email (Stage 0.4 notifications) ---
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=hrms@rashmigroup.com

# --- Object storage (Phase 3.5 — SeaweedFS per docs/14 §4) ---
# S3_ENDPOINT=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_BUCKET=hrms-uploads

# --- Production-only notes ---
# On the WHM server: file lives outside web root, chmod 600, NODE_ENV=production always set on PM2 (docs/02 §2; VBMS/EMS lesson).
